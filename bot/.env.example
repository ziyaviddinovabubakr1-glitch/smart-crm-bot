# Токен от @BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# URL вашей CRM (без / в конце)
# Локально: http://localhost:3000
# Production: https://your-crm.onrender.com
CRM_API_URL=http://localhost:3000

# Секрет — тот же, что TELEGRAM_WEBHOOK_SECRET в CRM (.env)
CRM_WEBHOOK_SECRET=random-secret-string

# Render задаёт PORT и RENDER_EXTERNAL_URL автоматически
PORT=8080
